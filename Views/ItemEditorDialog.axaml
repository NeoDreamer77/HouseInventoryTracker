<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HouseInventoryTracker.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
        x:Class="HouseInventoryTracker.Views.ItemEditorDialog"
        x:DataType="vm:MainWindowViewModel"
        Title="Item Editor"
        Width="500" Height="700"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Window.Styles>

    <Border Padding="20">
        <Grid RowDefinitions="*,Auto">
            <ScrollViewer Grid.Row="0">
                <StackPanel>
                    <TextBlock Classes="label" Text="Name *"/>
                    <TextBox Text="{Binding EditingItem.Name}" Watermark="Item name"/>

                    <TextBlock Classes="label" Text="Quantity"/>
                    <NumericUpDown Value="{Binding EditingItem.Quantity}" Minimum="1" Maximum="999999"/>

                    <TextBlock Classes="label" Text="Category"/>
                    <TextBox Text="{Binding EditingItem.Category}" Watermark="e.g., Electronics, Furniture"/>

                    <TextBlock Classes="label" Text="Location"/>
                    <TextBox Text="{Binding EditingItem.Location}" Watermark="e.g., Living Room, Garage"/>

                    <TextBlock Classes="label" Text="Description"/>
                    <TextBox Text="{Binding EditingItem.Description}" 
                             Watermark="Item description"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="100"/>

                    <TextBlock Classes="label" Text="Purchase Price"/>
                    <NumericUpDown Value="{Binding EditingItem.PurchasePrice}" 
                                  Minimum="0" 
                                  Maximum="999999999"
                                  FormatString="C"
                                  Increment="0.01"/>

                    <TextBlock Classes="label" Text="Purchase Date"/>
                    <CalendarDatePicker SelectedDate="{Binding EditingItem.PurchaseDate}"/>

                    <TextBlock Classes="label" Text="Photo Path"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding EditingItem.PhotoPath}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="5,0,0,0" Click="BrowsePhotoClick"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Cancel" Click="CancelClick" Width="100"/>
                <Button Content="Save" Click="SaveClick" Classes="accent" Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
