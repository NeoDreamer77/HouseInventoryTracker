<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:entities="using:HouseInventoryTracker.Domain.Entities"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
        x:Class="HouseInventoryTracker.Views.PrintPreviewWindow"
        Title="Print Preview - House Inventory"
        Width="650" Height="850"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Preview Content -->
        <Border Grid.Row="1" Margin="20" BorderBrush="Black" BorderThickness="1" Padding="20">
            <ScrollViewer>
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="House Inventory Report" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DateText" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <!-- Summary -->
                    <Border Background="#404040" Padding="10" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Summary" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                <TextBlock x:Name="TotalItemsText" Margin="0,5,0,0" Foreground="White"/>
                                <TextBlock x:Name="TotalValueText" Margin="0,5,0,0" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Filters Applied" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                <TextBlock x:Name="FilterText" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Items Table Header -->
                    <Border Background="DarkGray" Padding="5" Margin="0,0,0,5">
                        <Grid ColumnDefinitions="2*,*,*,*,*">
                            <TextBlock Grid.Column="0" Text="Name" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="Qty" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Category" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="3" Text="Location" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="4" Text="Price" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <!-- Items List -->
                    <ItemsControl x:Name="ItemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="entities:Item">
                                <Border Padding="5" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="2*,*,*,*,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Category}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Location}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding PurchasePrice, StringFormat=C}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Footer -->
                    <TextBlock Text="Generated by House Inventory Tracker" FontSize="10" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,20">
            <Button Content="Print" Click="PrintClick" Width="100" Classes="accent"/>
            <Button Content="Close" Click="CloseClick" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
